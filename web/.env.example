# ── Frontend environment (web/) ───────────────────────────────────────────────
# Only NEXT_PUBLIC_* values reach the browser. NEVER put a secret here — no API keys,
# no email creds, no model URL. Those live in api/.env only.

# Public base URL of the site (used for canonical URLs, sitemap, OpenGraph).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Public base URL of the Go backend the browser calls (contact + demo + health).
# This is a URL, not a secret.
NEXT_PUBLIC_API_URL=http://localhost:8080

# Cloudflare Turnstile SITE key (public). Leave blank to disable the widget locally.
# When set, it must pair with TURNSTILE_ENABLED=true + TURNSTILE_SECRET on the backend.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
